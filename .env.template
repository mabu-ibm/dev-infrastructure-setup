################################################################################
# Development Infrastructure Environment Template
# Copy this file to ~/.dev-infrastructure.env and fill in your values
################################################################################

# Gitea Configuration
export GITEA_URL="http://YOUR_BUILD_VM_IP:3000"
export GITEA_TOKEN="YOUR_GITEA_ACCESS_TOKEN"
export GITEA_USERNAME="YOUR_GITEA_USERNAME"
export GITEA_REGISTRY="YOUR_BUILD_VM_IP:3000"

# K3s Configuration
export K3S_URL="https://YOUR_K3S_VM_IP:6443"
export KUBECONFIG="${HOME}/.kube/k3s-config"

# VM Access
export BUILD_VM_IP="YOUR_BUILD_VM_IP"
export K3S_VM_IP="YOUR_K3S_VM_IP"

# Projects
export PROJECTS_DIR="${HOME}/projects"

# Git Configuration
export GIT_USER_NAME="Your Name"
export GIT_USER_EMAIL="your.email@example.com"

# Optional: Claude Code Configuration
# export CLAUDE_DIR="${HOME}/.claude/projects"

# Optional: IBM Bob Configuration
# export BOB_DIR="${HOME}/.bob/projects"

################################################################################
# Aliases (automatically loaded when sourced)
################################################################################

alias k='kubectl'
alias kgp='kubectl get pods'
alias kgs='kubectl get svc'
alias kgn='kubectl get nodes'
alias kga='kubectl get all -A'
alias klogs='kubectl logs -f'
alias kdesc='kubectl describe'

alias flux-status='flux get all -A'
alias flux-logs='flux logs --all-namespaces --follow'
alias flux-sync='flux reconcile source git'

alias gitea-ssh='ssh root@${BUILD_VM_IP}'
alias k3s-ssh='ssh root@${K3S_VM_IP}'

alias projects='cd ${PROJECTS_DIR}'

################################################################################
# Functions (automatically loaded when sourced)
################################################################################

# Create Gitea repository via API
gitea-create-repo() {
    local repo_name=$1
    if [ -z "${repo_name}" ]; then
        echo "Usage: gitea-create-repo <repo-name>"
        return 1
    fi
    
    curl -X POST "${GITEA_URL}/api/v1/user/repos" \
        -H "Authorization: token ${GITEA_TOKEN}" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"${repo_name}\",\"private\":false}"
}

# Update kubeconfig from K3s VM
k3s-kubeconfig() {
    scp root@${K3S_VM_IP}:/root/k3s-remote-kubeconfig.yaml ~/.kube/k3s-config
    echo "Kubeconfig updated. Test with: kubectl get nodes"
}

# Sync project chats manually
sync-project-chats() {
    local project_dir=${1:-$(pwd)}
    ~/dev-infrastructure-setup/chat-sync/sync-chats.sh "${project_dir}"
}

# Create new project
new-project() {
    local project_name=$1
    local stack_type=${2:-python}
    
    if [ -z "${project_name}" ]; then
        echo "Usage: new-project <name> [stack-type]"
        echo "Stack types: python, node, go, java, rust"
        return 1
    fi
    
    ~/dev-infrastructure-setup/project-templates/scaffold-project.sh "${project_name}" "${stack_type}"
}