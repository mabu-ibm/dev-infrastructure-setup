# Project Environment Configuration
# Copy this file to .env and fill in your values
# This file should be in your project root directory

################################################################################
# IBM Concert Configuration (Optional - for SBOM upload)
################################################################################

# Concert Instance URL
CONCERT_URL=https://YOUR_INSTANCE.concert.saas.ibm.com

# Concert API Key (from Concert UI: Settings > API Keys)
CONCERT_API_KEY=YOUR_CONCERT_API_KEY

# Concert Instance ID
CONCERT_INSTANCE_ID=YOUR_INSTANCE_ID

# Concert Application ID (optional, for SBOM association)
CONCERT_APPLICATION_ID=YOUR_APPLICATION_ID

################################################################################
# SBOM Configuration
################################################################################

# SBOM format (spdx-json, cyclonedx-json, syft-json)
SBOM_FORMAT=spdx-json

# SBOM output directory
SBOM_DIR=./sbom

################################################################################
# Application Configuration
################################################################################

# Application name
APP_NAME=${PROJECT_NAME}

# Application version
APP_VERSION=1.0.0

# Environment (development, staging, production)
ENVIRONMENT=development

################################################################################
# Kubernetes & Ingress Configuration
################################################################################

# Base domain for your infrastructure
BASE_DOMAIN=lab.allwaysbeginner.com

# Application hostname (will be: APP_NAME.BASE_DOMAIN)
# Example: my-app.lab.allwaysbeginner.com
APP_HOSTNAME=${APP_NAME}.${BASE_DOMAIN}

# K3s cluster hostname
K3S_HOSTNAME=almak3s.lab.allwaysbeginner.com

# Ingress class (traefik or nginx)
INGRESS_CLASS=traefik

# Enable TLS/HTTPS
ENABLE_TLS=true

# TLS secret name
TLS_SECRET_NAME=${APP_NAME}-tls

################################################################################
# Build Configuration
################################################################################

# Docker registry
DOCKER_REGISTRY=${GITEA_REGISTRY}

# Docker image name
DOCKER_IMAGE=${APP_NAME}

# Docker image tag
DOCKER_TAG=latest

################################################################################
# Development Configuration
################################################################################

# Local development port
DEV_PORT=8000

# Debug mode
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO